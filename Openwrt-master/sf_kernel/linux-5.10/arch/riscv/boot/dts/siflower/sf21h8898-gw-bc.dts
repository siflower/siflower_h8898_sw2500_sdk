/dts-v1/;
#include "sf21h8898-gw-bc.dtsi"


/ {
	model = "Siflower GW_BC (Booting from NOR)";
	compatible = "siflower,gw-bc", "siflower,sf21h8898";
};

&spi0_pins {
	pinctrl-single,pins = <
		SPI0_TXD	FUNC_MODE0
		SPI0_RXD	FUNC_MODE0
		SPI0_CLK	FUNC_MODE0
		SPI0_HOLD	FUNC_MODE0
		SPI0_WP		FUNC_MODE0
	>;
};

&spi0 {
	status = "okay";
	num-cs = <2>;
	cs-gpios = <&gpio 5 GPIO_ACTIVE_LOW>, <&gpio 19 GPIO_ACTIVE_LOW>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		m25p,fast-read;
		spi-max-frequency = <35000000>;
		spi-tx-bus-width = <2>;
		spi-rx-bus-width = <2>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "bootloader";
				reg = <0x0 0xc0000>;
				read-only;
			};

			partition@c0000 {
				label = "u-boot-env";
				reg = <0xc0000 0x10000>;
			};

			factory: partition@d0000 {
				label = "factory";
				reg = <0xd0000 0x10000>;
			};
		};
	};

	flash@1 {
		compatible = "spi-nand";
		reg = <1>;
		spi-max-frequency = <35000000>;
		spi-tx-bus-width = <2>;
		spi-rx-bus-width = <2>;
		#address-cells = <1>;
		#size-cells = <1>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "ubi";
				reg = <0x0 0x8000000>;
			};
		};
	};
};

#include "sf21h8898-factory.dtsi"
